# Certify Email Configuration
# Copy this file to certify-backend/.env or FSAD_CERTIFY/.env and fill in your values.
# Spring Boot now imports that .env file automatically when the backend starts.

# Gmail SMTP Settings (already configured in application.properties)
# These environment variables will override the defaults

# Your business Gmail address
SPRING_MAIL_USERNAME=your-business-email@gmail.com

# Gmail App Password (16 characters, not your regular password)
SPRING_MAIL_PASSWORD=your-16-character-app-password

# From address for emails (should match your Gmail)
APP_MAIL_FROM=your-business-email@gmail.com

# Optional: Enable/disable email sending
APP_MAIL_ENABLED=true

# Default expiry reminder window
APP_MAIL_EXPIRY_ALERT_DAYS=1

# Optional: set to true while debugging SMTP so startup validates the connection
SPRING_MAIL_TEST_CONNECTION=true
